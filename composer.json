{
	"name" : "viames/pair_boilerplate",
	"description" : "Skeleton project based on Pair PHP framework",
	"type" : "project",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"viames/pair": "dev-main"
	},
	"require-dev": {
		"phpunit/phpunit": "^12.0"
	},
	"scripts": {
		"post-install-cmd": [
			"php migrate-cli.php"
		],
		"post-update-cmd": [
			"php migrate-cli.php"
		],
		"pair": "php bin/pair",
		"test": "phpunit",
		"upgrade-to-v4": "php vendor/viames/pair/scripts/upgrade-to-v4.php"
	},
	"autoload": {
		"classmap": [
			"classes/",
			"modules/"
		],
		"exclude-from-classmap": [
			"modules/*/assets/",
			"modules/*/layouts/",
			"modules/*/translations/"
		]
	},
	"repositories" : [

		{
			"type" : "vcs",
			"url" : "https://github.com/viames/pair_boilerplate"
		}
	],
	"license" : "MIT",
	"keywords" : [
		"pair",
		"php",
		"multilingual",
		"framework",
		"active-record",
		"plugin-system",
		"pagination",
		"router",
		"rest-api",
		"oauth2"
	],
	"homepage" : "https://github.com/viames/pair_boilerplate",
	"authors" : [
		{
			"name" : "Viames Marino",
			"role" : "Developer"
		}
	],
	"config": {
		"allow-plugins": {
			"php-http/discovery": true
		}
	}
}
